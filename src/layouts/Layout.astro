---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
}

const { title = 'Travelastro' } = Astro.props;
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - EXPERIENCE</title>
    <script src="https://unpkg.com/htmx.org@2.0.4" defer></script>
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
    href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&family=Playfair+Display:wght@400;700;900&display=swap"
    rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <footer
      class="flex flex-col items-center gap-6 rounded p-10 text-center"
      style="background-color: #F4F4E8; color: #2C2C2C;">
      <nav class="flex flex-wrap justify-center gap-4">
        <a href="/about" class="hover:underline" style="color: #2C2C2C;" onmouseover="this.style.color='#D36E53'" onmouseout="this.style.color='#2C2C2C'">About us</a>
        <a href="/contact" class="hover:underline" style="color: #2C2C2C;" onmouseover="this.style.color='#D36E53'" onmouseout="this.style.color='#2C2C2C'">Contact</a>
        <a href="/jobs" class="hover:underline" style="color: #2C2C2C;" onmouseover="this.style.color='#D36E53'" onmouseout="this.style.color='#2C2C2C'">Jobs</a>
        <a href="/press" class="hover:underline" style="color: #2C2C2C;" onmouseover="this.style.color='#D36E53'" onmouseout="this.style.color='#2C2C2C'">Press kit</a>
      </nav>
      <nav>
        <div class="flex gap-4">
          <a href="https://www.tiktok.com/@voyaflair" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="hover:opacity-70 transition-opacity" style="color: #D36E53;">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              class="fill-current">
              <path
                d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V9.01a8.16 8.16 0 0 0 4.77 1.52V7.1a4.79 4.79 0 0 1-1.84-.41z"></path>
            </svg>
          </a>
          <a href="https://www.instagram.com/voyaflair" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:opacity-70 transition-opacity" style="color: #D36E53;">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              class="fill-current">
              <path
                d="M12 2.2c3.2 0 3.58.012 4.85.07 1.17.054 1.8.249 2.22.413.56.217.96.477 1.38.896.42.42.68.82.9 1.38.16.42.36 1.05.41 2.22.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.22-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.05.36-2.22.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.22-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.42-.36-1.05-.41-2.22C2.21 15.58 2.2 15.2 2.2 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.22.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.05-.36 2.22-.41C8.42 2.21 8.8 2.2 12 2.2zm0 1.8c-3.14 0-3.51.01-4.75.07-1.07.05-1.65.23-2.04.38-.51.2-.88.44-1.26.82-.38.38-.62.75-.82 1.26-.15.39-.33.97-.38 2.04C2.69 9.49 2.68 9.86 2.68 13s.01 3.51.07 4.75c.05 1.07.23 1.65.38 2.04.2.51.44.88.82 1.26.38.38.75.62 1.26.82.39.15.97.33 2.04.38 1.24.06 1.61.07 4.75.07s3.51-.01 4.75-.07c1.07-.05 1.65-.23 2.04-.38.51-.2.88-.44 1.26-.82.38-.38.62-.75.82-1.26.15-.39.33-.97.38-2.04.06-1.24.07-1.61.07-4.75s-.01-3.51-.07-4.75c-.05-1.07-.23-1.65-.38-2.04-.2-.51-.44-.88-.82-1.26-.38-.38-.75-.62-1.26-.82-.39-.15-.97-.33-2.04-.38C15.51 4.01 15.14 4 12 4zm0 3.06A4.94 4.94 0 1 1 12 17a4.94 4.94 0 0 1 0-9.94zm0 8.14a3.2 3.2 0 1 0 0-6.4 3.2 3.2 0 0 0 0 6.4zm6.3-8.34a1.15 1.15 0 1 1-2.3 0 1.15 1.15 0 0 1 2.3 0z"></path>
            </svg>
          </a>
          <a href="https://www.facebook.com/voyaflair" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:opacity-70 transition-opacity" style="color: #D36E53;">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              class="fill-current">
              <path
                d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"></path>
            </svg>
          </a>
        </div>
      </nav>
      <aside>
        <p class="text-sm" style="color: #2C2C2C;">Copyright {new Date().getFullYear()} - All rights reserved by <span style="color: #D36E53;">Travelastro</span></p>
      </aside>
    </footer>

    <script>
      // Scroll fade-in: toggles `.in-view` on `.fade-up` elements as they enter the viewport.
      const initFadeUp = () => {
        const els = document.querySelectorAll<HTMLElement>('.fade-up');
        if (!('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('in-view'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach((el) => io.observe(el));
      };

      initFadeUp();
      document.addEventListener('astro:page-load', initFadeUp);
    </script>
  </body>
</html>
