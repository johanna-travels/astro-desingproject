---
import { Image } from 'astro:assets';
import heroImg from '../assets/hero.jpg';
---


  <main class="hero-outer">
    <!-- Row A — Header / Intro section — same skeleton as Row B (grid-container, py-20, grid-row items-stretch); content centered -->
    <section class="grid-container relative py-20 bg-black">
      <!-- Row (Parent) — structural floor that spans the page -->
      <div class="grid-row">
        <!-- Column (12/12) — takes 100% horizontal space, display:flex -->
        <div class="grid-col col-12 flex" data-xl-width="12">
          <!-- Content-Wrapper (Child) — block child holding the actual text -->
          <div class="content-wrapper w-full block text-center text-sand p-0 m-0">
            <p class="text-sm tracking-[0.3em] uppercase opacity-70 mb-3">Travelastro · Experiences</p>
            <!--
              Heading
              • Font size: clamp(3.44rem, 12vw, 7.22rem)
                  → fluid: 55px on small screens, max 115.5px on huge screens,
                    scales with 12% of viewport width in between
              • Line-height: 0.9 (90%) → on a ~117px font that's ~105.7px per line
              • Computed height stays `auto` — line-height drives visual height,
                spans (display:inline) inherit it from the <p>/<h1>
            -->
            <!--
              Three inline <span>s separated by <br>:
              • Each span is display:inline → no own height
              • All three follow the parent's line-height (~105.7px)
              • Parent stacks them → total height ≈ 3 × 106 ≈ 332px
            -->
            <h1 class="font-display font-bold text-[clamp(3.44rem,12vw,7.22rem)] leading-[0.9]">
              <span>Discover the world,</span><br />
              <span>one story</span><br />
              <span>at a time.</span>
            </h1>
          </div>
        </div>
      </div>
    </section>

    <!-- Inner wrapper — dark hero panel containing only Row B (Split 5 / 1 / 5) -->
    <section id="wrapper" class="hero-section grid-container relative py-20 bg-black">
      <div class="grid-row items-stretch">

        <!-- Column 1 — 5/12 — Left content -->
        <div class="grid-col col-5" data-xl-width="5">
          <div class="h-full flex items-center bg-ink text-sand p-8 md:p-10">
            <div class="space-y-5 font-sans leading-relaxed">
              <p>
                I'm the founder &amp; creative director at
                <span class="font-semibold text-terracotta">✣HOVS</span>,
                a studio that builds and runs its own products — and occasionally works with partners such as NASA/JPL to brand their space missions.
              </p>
              <p>
                Currently growing <span class="font-semibold">mymind™</span>, my peaceful escape from the chaos of the internet.
              </p>
              <p>
                I'm also the co-founder of <span class="font-semibold">Semplice™</span> and <span class="font-semibold">Carbonmade™</span>, which have been serving the creative community for more than two decades.
              </p>
              <p>
                HOVS believes in brands and products that have a point of view. Take a look at some of our work
              </p>
              <p class="text-terracotta text-2xl">↓</p>
            </div>
          </div>
        </div>

        <!-- Column 2 — 1/12 — Divider -->
        <div class="grid-col col-1 flex justify-center" data-xl-width="1">
          <div class="hidden md:flex h-full items-center justify-center">
            <div class="flex flex-col items-center justify-center gap-4 h-1/2 min-h-[120px]">
              <div class="w-px flex-1 bg-white"></div>
              <div class="w-px flex-1 bg-white"></div>
            </div>
          </div>
        </div>

        <!-- Column 3 — 5/12 — Right content (portrait) -->
        <div class="grid-col col-5 mt-6 md:mt-0" data-xl-width="5">
          <div class="hero-bg h-full flex items-center justify-center p-4 md:p-6 will-change-transform">
            <div class="relative w-full max-w-sm md:max-w-md lg:max-w-lg aspect-[3/4] overflow-hidden bg-white p-1 shadow-2xl ring-1 ring-white/30">
              <div class="relative w-full h-full overflow-hidden">
                <img
                  src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1200&q=80"
                  alt="Tropical beach at sunset"
                  class="w-full h-full object-cover"
                />
                <!-- Dark overlay to soften / darken the image -->
                <div class="pointer-events-none absolute inset-0 bg-black/35"></div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>
  </main>





<script>
  // Lazy-load GSAP only when this component is on the page
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initHero() {
    const section = document.querySelector('.hero-section');
    if (!section) return;

    // Scroll-triggered column reveal
    // Trigger is the .row entering the viewport — all columns animate together
    // (staggered) the moment the row's top hits 85% of the screen.
    const row = section.querySelector('.row');
    if (row) {
      gsap.fromTo(
        section.querySelectorAll('.col'),
        { y: 60, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 1,
          ease: 'power3.out',
          stagger: 0.15,
          scrollTrigger: {
            trigger: row,
            start: 'top 85%',
            end: 'top 40%',
            toggleActions: 'play none none reverse',
          },
        }
      );
    }

    // Subtle parallax on the right-side image as you keep scrolling
    gsap.to('.hero-bg', {
      yPercent: -10,
      ease: 'none',
      scrollTrigger: {
        trigger: '.hero-section',
        start: 'top bottom',
        end: 'bottom top',
        scrub: true,
      },
    });
  }

  // Re-init on Astro view transitions too
  document.addEventListener('astro:page-load', initHero);
</script>
