---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Carousel from '../components/carousel.astro';
---

<Layout title="Travelastro">
  <Hero />

  <section id="stories" class="py-24 px-6 max-w-5xl mx-auto text-center">
    <h2>Latest stories</h2>
    <p class="mt-4 opacity-70">Scroll back up to see the parallax in action.</p>
    <div class="mt-10">
      <button>Click me</button>
    </div>
  </section>

  <Carousel />
    
  
